// ?슚 @PATCH : None
// ?뵕 @CALLS : document.documentElement.classList.add/remove
// ====================================================================

  useEffect(() => {
    if (!mounted) return;
    if (isDarkMode) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }, [isDarkMode, mounted]);

