        domReadOnly: licenseStatus.isExpired,
      });
      // 3. ?덉씠?꾩썐 由ы뵆濡쒖슦 媛뺤젣 ?몃━嫄?(李뚭렇?ъ쭚 諛⑹?)
      requestAnimationFrame(() => {
        editorRef.current?.layout();
      });
    }
  }, [themePalette, fontSize, wordWrap, mounted, isEditorReady, licenseStatus.isExpired]);

