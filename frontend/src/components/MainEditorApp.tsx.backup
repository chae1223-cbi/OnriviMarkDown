// ====================================================================
  useEffect(() => {
    if (!mounted) return;
    if (isDarkMode) {
      const currentTheme = THEME_MAP[themePalette];
      if (!currentTheme || !currentTheme.isDark) {
        setThemePalette('onrivi-dark');
      }
    } else {
      const currentTheme = THEME_MAP[themePalette];
      if (!currentTheme || currentTheme.isDark) {
        setThemePalette('onrivi-light');
      }
    }
  }, [isDarkMode, mounted, themePalette]);

